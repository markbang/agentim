# AgentIM Configuration
# Copy this file to .env and fill in your credentials

# ============================================
# AI Agent Credentials
# ============================================

# Anthropic Claude API
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (for Codex)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pi AI
# Get your API key from: https://pi.ai/
PI_API_KEY=pi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Channel Credentials
# ============================================

# Telegram Bot Token
# Create a bot with @BotFather on Telegram
# Format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Discord Bot Token
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Feishu/Lark Credentials
# Create an app at: https://open.feishu.cn/
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_FEISHU_APP_SECRET

# QQ Bot Credentials
# Create a bot at: https://bot.q.qq.com/
QQ_BOT_ID=YOUR_QQ_BOT_ID
QQ_BOT_TOKEN=YOUR_QQ_BOT_TOKEN

# ============================================
# Optional Configuration
# ============================================

# Log level (debug, info, warn, error)
RUST_LOG=info

# Server port (if running as a service)
SERVER_PORT=8080

# Database URL (for future persistence)
# DATABASE_URL=sqlite:agentim.db

{
  "agent": "openai",
  "telegram_agent": null,
  "discord_agent": null,
  "feishu_agent": null,
  "qq_agent": null,
  "slack_agent": null,
  "dingtalk_agent": null,
  "openai_api_key": "${OPENAI_API_KEY}",
  "openai_base_url": "https://api.openai.com/v1",
  "openai_model": "gpt-4o-mini",
  "openai_max_retries": 3,
  "routing_rules": [],
  "telegram_token": "${TELEGRAM_BOT_TOKEN}",
  "telegram_webhook_secret_token": null,
  "discord_token": "${DISCORD_BOT_TOKEN}",
  "discord_interaction_public_key": null,
  "feishu_token": "${FEISHU_APP_ID}:${FEISHU_APP_SECRET}",
  "feishu_app_id": null,
  "feishu_app_secret": null,
  "feishu_verification_token": null,
  "qq_token": "${QQ_BOT_ID}:${QQ_BOT_TOKEN}",
  "qq_bot_id": null,
  "qq_bot_token": null,
  "slack_token": "${SLACK_BOT_TOKEN}",
  "slack_signing_secret": "${SLACK_SIGNING_SECRET}",
  "dingtalk_token": "${DINGTALK_ACCESS_TOKEN}",
  "dingtalk_secret": "${DINGTALK_SECRET}",
  "state_file": "/app/state/sessions.json",
  "state_backup_count": 3,
  "max_session_messages": 100,
  "context_message_limit": 20,
  "agent_timeout_ms": 30000,
  "webhook_secret": "${WEBHOOK_SECRET}",
  "webhook_signing_secret": null,
  "webhook_max_skew_seconds": 300,
  "addr": "0.0.0.0:8080"
}
